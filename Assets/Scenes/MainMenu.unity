MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1334818181}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 7e8ff16251401cf4f81bc2f4ecbb4430, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  command: "$root = $PSScriptRoot\n$venv = Join-Path $root '.venv_export'\nif (-not
    (Test-Path $venv)) { py -3 -m venv $venv }\n$python = Join-Path $venv 'Scripts\\python.exe'\nif
    (-not (Test-Path $python)) {\n    Write-Error \"venv python not found: $python\"\n   
    exit 1\n}\nWrite-Output \"Using venv python: $python\"\n\n# Upgrade pip (safe
    and idempotent)\nWrite-Output \"Upgrading pip...\"\n& $python -m pip install
    --upgrade pip\n\n# NOTE: do NOT upgrade/install mlagents here to avoid changing
    pinned deps in the export venv.\n# If you really need to install mlagents in
    this venv, uncomment the next two lines.\n# Write-Output \"Installing/updating
    mlagents...\"\n# & $python -m pip install -U mlagents\n\n# Prefer mlagents-learn
    executable if present in Scripts\n$mlExe = Join-Path $venv 'Scripts\\mlagents-learn.exe'\nif
    (Test-Path $mlExe) {\n    Write-Output \"Found mlagents-learn executable: $mlExe\"\n   
    & $mlExe \".\\Assets\\training\\trainer_config.yaml\" --run-id \"FighterRun14\"
    --force\n} else {\n    Write-Output \"mlagents-learn.exe not found, falling back
    to python -m mlagents_learn\"\n    & $python -m mlagents_learn \".\\Assets\\training\\trainer_config.yaml\"
    --run-id \"FighterRun14\" --force\n}"
  workingDirectory: 
  usePowerShell: 0
  startTensorboard: 0
  tensorboardCommand: tensorboard --logdir results
  logProcessOutput: 1
  keepTempPs1: 0
